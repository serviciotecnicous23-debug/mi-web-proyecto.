<icecast>
  <location>Austin, Texas</location>
  <admin>admin@ministerioavivandoelfuego.com</admin>
  <limits>
    <clients>100</clients>
    <sources>2</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
  </limits>
  <authentication>
    <source-password>change-source-password</source-password>
    <relay-password>change-relay-password</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>change-admin-password</admin-password>
  </authentication>
  <hostname>radio.ministerioavivandoelfuego.com</hostname>
  <listen-socket>
    <port>8000</port>
  </listen-socket>
  <mount>
    <mount-name>/radio.mp3</mount-name>
    <public>1</public>
  </mount>
  <fileserve>1</fileserve>
  <paths>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
  </paths>
  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
  </logging>
</icecast>
